# ============================================================
# Accuretta — public repo gitignore
# data/settings.json is the SEED defaults and is tracked.
# Everything else under data/ is per-user runtime state.
# ============================================================

# user runtime state — chats, memories, workspace, snapshots, system context
data/*
!data/settings.json
!data/.gitkeep

# python
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.venv/
venv/
env/
.env
.env.*
!.env.example

# editor / OS / tool cruft
node_modules/
.vscode/
.idea/
.claude/
.cursor/
.cline/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# build / logs
*.log
*.tmp
build/
coverage/

# safety net — stray runtime files outside data/
ACCURETTA.md
chats.json
workspace.json
memories.jsonl
approvals.json
versions/
snapshots/
pending/
